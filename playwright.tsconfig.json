{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2016",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitThis": false,
    "noImplicitAny": false
  },
  "paths": {
    "@/*": ["./playwright/*"]
  },
  "include": ["playwright/**/*.ts"],
  "exclude": ["node_modules"]
}
