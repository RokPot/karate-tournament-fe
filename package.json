{
  "name": "karate-app-fe",
  "description": "karate app fe app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "bootstrap:local": "npx tsx scripts/bootstrap-env.ts local",
    "bootstrap:dev": "npx tsx scripts/bootstrap-env.ts dev",
    "bootstrap:prd": "npx tsx scripts/bootstrap-env.ts prd",
    "dev:local": "yarn bootstrap:local && next dev",
    "dev:dev": "yarn bootstrap:dev && next dev",
    "dev:prd": "yarn bootstrap:prd && next dev",
    "dev": "yarn dev:local",
    "bundle-analyzer": "ANALYZE=true STAGE=local next build",
    "test:watch": "STAGE=local jest --watch --runInBand",
    "test": "STAGE=local jest --runInBand --forceExit",
    "build": "next build",
    "build:docker": "./scripts/docker/build-docker-image.sh",
    "start": "next start",
    "lint": "next lint --dir .",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o ./dist/storybook",
    "svg": "npx @svgr/cli --config-file ./svg/.svgrrc.js -- svg/icons && prettier --write ./src/assets/icons",
    "i18n:missing": "npx tsx scripts/i18n/find-missing-translations.ts",
    "test:e2e": "TS_NODE_PROJECT=\"playwright.tsconfig.json\" node -r ts-node/register -r tsconfig-paths/register node_modules/.bin/cucumber-js",
    "test:e2e-ci": "TS_NODE_PROJECT=\"playwright.tsconfig.json\" node -r ts-node/register -r tsconfig-paths/register node_modules/.bin/cucumber-js --world-parameters \"{ \\\"headless\\\": true }\"",
    "test:e2e-tags": "TS_NODE_PROJECT=\"playwright.tsconfig.json\" cucumber-js --require-module ts-node/register --require playwright/tests/cucumber/support/**/*.ts --require playwright/tests/cucumber/stepDefinitions/**/*.ts --tags @run --format @cucumber/pretty-formatter --world-parameters \"{ \\\"browserName\\\": \\\"firefox\\\", \\\"headless\\\": false }\" ./playwright/tests/cucumber/features/*.feature",
    "data:gen": "npx tsx scripts/data/generate-data-files.ts",
    "codegen": "yarn openapi-codegen generate --input 'http:localhost:3002/docs-json' --output src/data"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.3.0",
    "@auth0/nextjs-auth0": "^4.13.2",
    "@cucumber/cucumber": "^11.2.0",
    "@cucumber/pretty-formatter": "^1.0.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-regular-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@hookform/resolvers": "^3.10.0",
    "@internationalized/date": "^3.8.2",
    "@mui/material": "^7.3.6",
    "@next/bundle-analyzer": "^15.1.6",
    "@playwright/test": "^1.50.0",
    "@react-aria/i18n": "^3.12.11",
    "@react-stately/calendar": "^3.8.3",
    "@react-stately/datepicker": "^3.15.0",
    "@react-types/shared": "^3.31.0",
    "@sentry/cli": "^2.42.3",
    "@sentry/react": "^8.51.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@tanstack/react-query": "^5.80.1",
    "@tanstack/react-query-devtools": "^5.76.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.12",
    "@tanstack/virtual-core": "^3.13.12",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "i18next": "^24.2.2",
    "immer": "^10.1.1",
    "jose": "^5.9.6",
    "js-yaml": "^4.1.1",
    "lodash-es": "^4.17.21",
    "loglevel": "^1.9.2",
    "loglevel-plugin-prefix": "^0.8.4",
    "luxon": "^3.5.0",
    "next": "15.1.9",
    "next-seo": "^6.6.0",
    "pdfjs-dist": "5.0.375",
    "rand-seed": "^2.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.55.0",
    "react-i18next": "^15.4.0",
    "react-responsive": "^10.0.0",
    "react-stately": "^3.40.0",
    "react-toastify": "^11.0.3",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.33.5",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^4.1.17",
    "typescript": "5.5.4",
    "ua-parser-js": "^2.0.5",
    "usehooks-ts": "^3.1.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.1",
    "@povio/openapi-codegen-cli": "^0.10.0",
    "@storybook/addon-a11y": "^8.5.3",
    "@storybook/addon-controls": "^8.5.3",
    "@storybook/addon-essentials": "^8.5.3",
    "@storybook/addon-interactions": "^8.5.3",
    "@storybook/addon-links": "^8.5.3",
    "@storybook/addon-onboarding": "^8.5.3",
    "@storybook/blocks": "^8.5.3",
    "@storybook/nextjs": "^8.5.3",
    "@storybook/preview-api": "^8.5.3",
    "@storybook/react": "^8.5.3",
    "@storybook/test": "^8.5.3",
    "@svgr/cli": "^8.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.1",
    "@types/css": "^0.0.38",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.10",
    "@types/react": "18.2.42",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "axios-mock-adapter": "^2.1.0",
    "css": "^3.0.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-next": "^14.2.23",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.15.1",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-storybook": "^0.9.0",
    "eslint-plugin-tailwind-v4": "^1.0.15",
    "eslint-plugin-unused-imports": "^3.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "leaked-handles": "^5.2.0",
    "lint-staged": "^15.4.3",
    "msw": "^2.7.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^8.5.3",
    "ts-node": "^10.9.2"
  },
  "packageManager": "yarn@4.6.0",
  "resolutions": {
    "eslint-plugin-react-hooks": "4.6.2"
  },
  "lint-staged": {
    "./**/*.js": "prettier --write",
    "./**/*.{ts,tsx}": [
      "eslint",
      "prettier --write"
    ],
    "./**/*.{htm,html,yml,yaml,json}": "prettier --write"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "overrides": {}
}
